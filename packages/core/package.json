{
  "name": "hds-core",
  "version": "5.0.0",
  "description": "Core styles for the Helsinki Design System",
  "homepage": "https://github.com/City-of-Helsinki/helsinki-design-system#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/City-of-Helsinki/helsinki-design-system.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^22.13.1"
  },
  "browserslist": "> 0.2%, not iOS < 15, not Safari < 14.5, not dead, not op_mini all, not Android >= 0, not and_uc >= 0",
  "main": "lib/base.min.css",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rimraf lib/ && node scripts/fBuilder.js && yarn run lint:styles && yarn postcss-build && yarn css-to-ts && yarn copy-scss-files && yarn copy-scss-fonts && yarn copy-scss-utils && yarn cssToScss",
    "clean": "rimraf node_modules lib storybook-static",
    "start": "yarn storybook",
    "scss-tests": "yarn jest",
    "postcss-build": "postcss 'src/**/[!_]*.(css|scss)' --base src -d lib --ext .css && postcss 'src/**/[!_]*.(css|scss)' --base src -d lib --ext 'min.css' --env 'minify'",
    "postcss-watch": "postcss 'src/**/*.(css|scss)' --base src -d lib --watch",
    "cssToScss": "node scripts/cssToScss.js",
    "copy-scss-files": "node copyFiles -source 'src/components/**/_*.scss' -target 'lib/components' -v",
    "copy-scss-fonts": "node copyFiles -source 'src/fonts/*.scss' -target 'lib/fonts' -v",
    "copy-scss-utils": "node copyFiles -source 'src/utils/**/_*.scss' -target 'lib/utils' -v",
    "css-to-ts": "node cssToImportableString -directory 'lib/components/**/*.min.css' -targetFiles 'cookieConsent.min.css'",
    "storybook": "storybook dev -p 6007 --quiet",
    "build-storybook": "storybook build --loglevel error",
    "lint:styles": "yarn stylelint \"src/**/*.(css|scss)\" --ip \"src/**/__tests__/*.scss\"",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@csstools/postcss-sass": "^5.1.1",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.0",
    "@storybook/html-webpack5": "^8.6.0",
    "storybook": "^8.6.0",
    "babel-jest": "^29.7.0",
    "copyfiles": "2.2.0",
    "css-loader": "5.2.6",
    "cssnano": "^5.1.15",
    "glob": "^10.4.1",
    "hds-design-tokens": "5.0.0",
    "jest": "^29.7.0",
    "postcss": "8.4.31",
    "postcss-classes-to-mixins": "^3.0.1",
    "postcss-cli": "8.3.1",
    "postcss-import": "12.0.1",
    "postcss-inline-svg": "4.1.0",
    "postcss-preset-env": "^7.8.3",
    "postcss-sass": "^0.5.0",
    "rimraf": "3.0.2",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "sass-loader": "10.1.1",
    "sass-true": "^8.0.0",
    "style-loader": "2.0.0",
    "stylelint": "^15.1.0",
    "stylelint-config-css-modules": "^4.2.0",
    "stylelint-config-standard": "^30.0.1",
    "stylelint-config-standard-scss": "^7.0.1",
    "stylelint-order": "^6.0.2"
  }
}
