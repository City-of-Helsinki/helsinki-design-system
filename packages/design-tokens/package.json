{
  "name": "hds-design-tokens",
  "version": "6.0.3",
  "description": "Design tokens for the Helsinki Design System",
  "homepage": "https://github.com/City-of-Helsinki/helsinki-design-system#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/City-of-Helsinki/helsinki-design-system.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^24.17.0"
  },
  "main": "lib/all.css",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm build-tokens && pnpm minify-css",
    "build-tokens": "node build.js",
    "minify-css": "foreach -g \"lib/**/*.css\" -i \"lib/**/*.min.css\" -t 10 -x \"pnpm cleancss -o #{dir}/#{name}.min.css #{path}\""
  },
  "devDependencies": {
    "clean-css-cli": "4.3.0",
    "foreach-cli": "1.8.1",
    "style-dictionary": "2.10.0"
  }
}
