{
  "name": "site",
  "private": true,
  "description": "Documentation for Helsinki Design System",
  "version": "6.0.3",
  "engines": {
    "node": "^24"
  },
  "dependencies": {
    "@mdx-js/react": "2.3.0",
    "extract-zip": "^2.0.1",
    "gatsby": "5.16.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-matomo": "^0.17.0",
    "gatsby-plugin-mdx": "5.16.0",
    "gatsby-plugin-no-sourcemaps": "5.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-robots-txt": "^1.8.0",
    "gatsby-plugin-sass": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-remark-autolink-headers": "^6.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "5.16.0",
    "html-validate": "6.5.0",
    "path-browserify": "^1.0.1",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-helmet": "^6.1.0",
    "react-live": "4.1.8",
    "remark-gfm": "^1",
    "sanitize-html": "^2.17.3",
    "sass": "^1.49.9",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-syntax-flow": "^7.23.3",
    "@babel/plugin-transform-react-jsx": "^7.23.4",
    "chalk": "4.0.0",
    "crypto-browserify": "^3.11.0",
    "eslint": "8.56.0",
    "eslint-config-react-app": "^7.0.1",
    "hds-core": "6.0.3",
    "hds-design-tokens": "6.0.3",
    "hds-react": "6.0.3",
    "inquirer": "7.1.0",
    "postcss": "8",
    "prettier": "2.5.1",
    "stylelint": "^15.1.0",
    "stylelint-config-standard-scss": "^7.0.1",
    "stylelint-order": "^6.0.2"
  },
  "keywords": [
    "gatsby",
    "hds"
  ],
  "license": "MIT",
  "scripts": {
    "check-versions": "node scripts/check-versions.mjs",
    "build": "pnpm check-versions && pnpm lint && NODE_OPTIONS='--max_old_space_size=8192 --disable-warning=DEP0040' gatsby build",
    "build-single-version": "pnpm lint && NODE_OPTIONS='--max_old_space_size=8192 --disable-warning=DEP0040' BUILD_SINGLE_VERSION=true gatsby build",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "NODE_OPTIONS='--max_old_space_size=8192 --disable-warning=DEP0040' BUILD_SINGLE_VERSION=true gatsby develop -o",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "link-react": "rm -rf node_modules/hds-react/lib && cp ../packages/react/package.json node_modules/hds-react/ && cp -r ../packages/react/lib node_modules/hds-react/",
    "link-core": "rm -rf node_modules/hds-core/lib/* && cp -r ../packages/core/lib/* node_modules/hds-core/lib/",
    "lint:js": "pnpm eslint . --ext js",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint": "pnpm lint:js && pnpm lint:scss",
    "scaffold": "node scripts/scaffold.js",
    "iconlist": "node scripts/iconlist.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/City-of-Helsinki/helsinki-design-system"
  },
  "bugs": {
    "url": "https://github.com/City-of-Helsinki/helsinki-design-system/issues"
  }
}
